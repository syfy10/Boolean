<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows10.0.19041.0</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>saz</AssemblyName>
    <RootNamespace>SazShell</RootNamespace>
    <Version>0.9.17</Version>
    <FileVersion>0.9.17.0</FileVersion>
    <AssemblyVersion>0.9.17.0</AssemblyVersion>
    <ApplicationIcon>..\assets\saz.ico</ApplicationIcon>
    <!-- single self-contained file is produced by the publish step in build-shell.ps1 -->
    <SatelliteResourceLanguages>en</SatelliteResourceLanguages>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.2903.40" />
  </ItemGroup>

  <ItemGroup>
    <!-- ship the icon next to the exe so the sidecar / window can load it -->
    <None Include="..\assets\saz.ico" CopyToOutputDirectory="PreserveNewest" Link="saz.ico" />
  </ItemGroup>

</Project>
