{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "boolean-cloud",
  "main": "src/worker.js",
  "compatibility_date": "2026-07-14",
  "workers_dev": true,
  "preview_urls": true,
  "routes": [
    {
      "pattern": "saz3.com/boolean/auth/*",
      "zone_name": "saz3.com"
    },
    {
      "pattern": "saz3.com/boolean/admin*",
      "zone_name": "saz3.com"
    }
  ],
  "observability": {
    "enabled": true
  },
  "vars": {
    "APP_NAME": "Boolean",
    "PUBLIC_APP_URL": "https://saz3.com/boolean",
    "PUBLIC_AUTH_BASE_URL": "https://saz3.com/boolean",
    "ALLOWED_ORIGINS": "http://localhost:8765",
    "ADMIN_EMAILS": "syfy10@gmail.com",
    "FREE_TIER_PROVIDER": "workers-ai",
    "FREE_TIER_MODEL": "@cf/qwen/qwen3-30b-a3b-fp8"
  },
  "ai": {
    "binding": "AI"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "boolean-cloud",
      "database_id": "a971c58e-5482-4dc7-8af3-d2683aa3ba65",
      "migrations_dir": "./migrations"
    }
  ]
}
